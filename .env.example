# InvoMatch environment selection
INVOMATCH_ENV=local

# Persistence backends
INVOMATCH_RUN_STORE_BACKEND=sqlite
INVOMATCH_REVIEW_STORE_BACKEND=sqlite
INVOMATCH_FEEDBACK_STORE_BACKEND=sqlite
INVOMATCH_MATCH_RECORD_STORE_BACKEND=sqlite

# Persistence paths
INVOMATCH_RUN_STORE_PATH=output/local/reconciliation_runs.sqlite3
INVOMATCH_REVIEW_STORE_PATH=output/local/review_store.sqlite3
INVOMATCH_FEEDBACK_STORE_PATH=output/local/feedback_store.sqlite3
INVOMATCH_MATCH_RECORD_STORE_PATH=output/local/match_records.sqlite3
INVOMATCH_EXPORT_ARTIFACT_DB_PATH=output/local/export_artifacts.sqlite3
INVOMATCH_INPUT_SESSION_DB_PATH=output/local/input_sessions.sqlite3
INVOMATCH_INGESTION_BATCH_ROOT=output/local/ingestion_batches

# Storage paths
INVOMATCH_ARTIFACT_ROOT_PATH=output/local/artifacts
INVOMATCH_EXPORT_DIRECTORY=output/local/exports
INVOMATCH_UPLOAD_ROOT_PATH=output/local/uploads
INVOMATCH_TEMP_DIRECTORY=output/local/tmp
INVOMATCH_LOG_DIRECTORY=output/local/logs

# Runtime
INVOMATCH_LEASE_SECONDS=60
INVOMATCH_RETRY_BUDGET=3
INVOMATCH_STUCK_RUN_TIMEOUT_SECONDS=600
INVOMATCH_RECOVERY_SCAN_INTERVAL_SECONDS=60
INVOMATCH_RUNTIME_RECOVERY_ENABLED=true
INVOMATCH_STARTUP_REPAIR_ENABLED=true
INVOMATCH_STARTUP_VALIDATION_ENABLED=true

# Observability
INVOMATCH_LOG_LEVEL=INFO
INVOMATCH_STRUCTURED_LOGGING_ENABLED=false
INVOMATCH_METRICS_ENABLED=true
INVOMATCH_RUNTIME_EVENT_LOGGING_ENABLED=true
INVOMATCH_STARTUP_REPORT_LOGGING_ENABLED=true

# Upload
INVOMATCH_UPLOAD_MAX_FILE_SIZE_MB=25
INVOMATCH_UPLOAD_TEMP_RETENTION_HOURS=24

# Scheduler
INVOMATCH_SCHEDULER_ENABLED=false
INVOMATCH_SCHEDULER_DEFAULT_SCAN_LIMIT=100
INVOMATCH_SCHEDULER_TICK_INTERVAL_SECONDS=60

# Feature flags
INVOMATCH_ENABLE_REVIEW_PERSISTENCE=true
INVOMATCH_ENABLE_FEEDBACK_LEARNING=true
INVOMATCH_ENABLE_EXPORT_ARTIFACTS=true
INVOMATCH_ENABLE_RUNTIME_RECOVERY=true
INVOMATCH_ENABLE_STARTUP_REPAIR=true